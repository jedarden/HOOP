{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hoop.dev/schemas/hoop_config.json",
  "title": "HoopConfig",
  "description": "HOOP daemon configuration from config.yml. See §17.4 for hot-reload semantics.",
  "type": "object",
  "required": ["schema_version"],
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "additionalProperties": false,
      "description": "Server configuration. Keys marked restart_required require daemon restart to take effect (§17.4).",
      "properties": {
        "bind_addr": {
          "type": "string",
          "description": "Socket address for the HTTP server (default: 127.0.0.1:3000). REQUIRES RESTART - socket binding is established at daemon startup (§17.4).",
          "restart_required": true
        }
      }
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0",
      "description": "Schema version for compatibility tracking (SemVer)"
    },
    "agent": {
      "$ref": "agent_config.json"
    },
    "projects_file": {
      "type": "string",
      "description": "Path to projects.yaml (default ~/.hoop/projects.yaml)"
    },
    "backup": {
      "$ref": "backup_config.json"
    },
    "ui": {
      "$ref": "ui_config.json"
    },
    "voice": {
      "$ref": "voice_config.json"
    },
    "agent_extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills": {
          "type": "string",
          "description": "Path to skills directory"
        },
        "scripts": {
          "type": "string",
          "description": "Path to scripts directory"
        },
        "notes": {
          "type": "string",
          "description": "Path to notes directory"
        },
        "prompts": {
          "type": "string",
          "description": "Path to prompts directory"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "port": {
          "type": "integer",
          "default": 9091,
          "description": "Metrics server port (default: 9091). REQUIRES RESTART when metrics.enabled=true - server binding is established at daemon startup (§17.4).",
          "restart_required": true
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retention_days": {
          "type": "integer",
          "default": 90
        },
        "hash_chain": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "reflection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "detection_threshold": {
          "type": "number",
          "default": 0.8
        },
        "auto_archive_after_days": {
          "type": "integer",
          "default": 30
        }
      }
    },
    "pricing": {
      "$ref": "pricing_config.json"
    }
  }
}
