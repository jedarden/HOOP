{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hoop.dev/schemas/session_message.json",
  "title": "SessionMessage",
  "description": "A single message in a CLI session transcript",
  "type": "object",
  "required": ["role", "content"],
  "properties": {
    "role": {
      "type": "string",
      "description": "Message role (user, assistant, system, tool)"
    },
    "content": {
      "description": "Message content (may be text or structured for tool use)"
    },
    "usage": {
      "$ref": "message_usage.json"
    },
    "timestamp": {
      "type": ["string", "null"],
      "description": "Message timestamp if available",
      "format": "date-time"
    }
  },
  "schema_version": "1.0.0"
}
