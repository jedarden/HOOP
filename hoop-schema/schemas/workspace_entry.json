{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hoop.dev/schemas/workspace_entry.json",
  "title": "WorkspaceEntry",
  "description": "A workspace entry within a project",
  "type": "object",
  "required": ["path", "role"],
  "properties": {
    "path": {
      "type": "string",
      "description": "Absolute path to the workspace"
    },
    "role": {
      "type": "string",
      "enum": ["primary", "manifests", "source", "secrets", "docs"],
      "description": "Workspace role"
    }
  },
  "schema_version": "1.0.0"
}
