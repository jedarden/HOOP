{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hoop.dev/schemas/bead.json",
  "title": "Bead",
  "description": "A tracking bead (issue/task) in the beads system",
  "type": "object",
  "required": ["id", "title", "status", "priority", "issue_type", "created_at", "updated_at", "created_by", "dependencies", "schema_version"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Bead ID (e.g., hoop-ttb.1)"
    },
    "title": {
      "type": "string",
      "description": "Bead title"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Bead description"
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed"],
      "description": "Bead status"
    },
    "priority": {
      "type": "integer",
      "description": "Priority (0 = highest)"
    },
    "issue_type": {
      "type": "string",
      "enum": ["task", "bug", "epic", "genesis", "review", "fix"],
      "description": "Issue type"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "created_by": {
      "type": "string",
      "description": "Creator username"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of dependent bead IDs"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    }
  },
  "schema_version": "1.0.0"
}
