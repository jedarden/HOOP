{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hoop.dev/schemas/debug_state.json",
  "title": "DebugState",
  "description": "Complete daemon state snapshot for incident triage (§16.8, §M3). Field additions require a schema bump (§20).",
  "type": "object",
  "required": [
    "schema_version",
    "uptime_secs",
    "version",
    "config_hash",
    "bind_addr",
    "workers",
    "worker_pids",
    "active_claims",
    "ws_clients",
    "session_alias_table",
    "backup_timestamps",
    "fleet_db_path",
    "fleet_db_size_bytes",
    "fleet_db_wal_size_bytes",
    "open_stitches",
    "total_beads",
    "projects"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer version of this payload schema. Bump on any field addition or removal (§20)."
    },
    "uptime_secs": {
      "type": "integer",
      "minimum": 0,
      "description": "Seconds elapsed since the daemon process started."
    },
    "version": {
      "type": "object",
      "required": ["daemon", "schema"],
      "additionalProperties": false,
      "properties": {
        "daemon": {
          "type": "string",
          "description": "hoop-daemon Cargo package version (semver)."
        },
        "schema": {
          "type": "string",
          "description": "hoop-schema SCHEMA_VERSION constant."
        }
      },
      "description": "Version identifiers for the running daemon and schema crate."
    },
    "config_hash": {
      "type": "string",
      "description": "SHA-256 hex digest of the serialised resolved config (§17.2). Changes when any config key changes source or value."
    },
    "bind_addr": {
      "type": "string",
      "description": "Socket address the HTTP server is bound to."
    },
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "state", "liveness", "last_heartbeat", "heartbeat_age_secs"],
        "additionalProperties": false,
        "properties": {
          "name":               { "type": "string" },
          "state":              { "type": "string", "description": "Formatted WorkerDisplayState (e.g. 'Executing { bead: … }')." },
          "liveness":           { "type": "string", "enum": ["Live", "Hung", "Dead"] },
          "last_heartbeat":     { "type": "string", "format": "date-time" },
          "heartbeat_age_secs": { "type": "integer" },
          "pid":                { "type": ["integer", "null"], "minimum": 1, "description": "Last observed OS PID for this worker, null when not in Executing state." }
        }
      },
      "description": "All workers currently known to the registry with full liveness detail."
    },
    "worker_pids": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["worker", "pid"],
        "additionalProperties": false,
        "properties": {
          "worker": { "type": "string" },
          "pid":    { "type": "integer", "minimum": 1 }
        }
      },
      "description": "Every worker PID observed (latest PID per worker name). Useful for kill -0 checks."
    },
    "active_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["worker", "bead", "adapter"],
        "additionalProperties": false,
        "properties": {
          "worker":  { "type": "string" },
          "bead":    { "type": "string" },
          "adapter": { "type": "string" },
          "pid":     { "type": ["integer", "null"], "minimum": 1 }
        }
      },
      "description": "Every currently active claim: workers in Executing state with the bead they hold."
    },
    "ws_clients": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["conn_id", "connected_at", "connected_secs"],
        "additionalProperties": false,
        "properties": {
          "conn_id":        { "type": "integer", "minimum": 1 },
          "connected_at":   { "type": "string", "format": "date-time" },
          "connected_secs": { "type": "integer", "minimum": 0 }
        }
      },
      "description": "Every currently connected WebSocket client with its connection ID and age."
    },
    "session_alias_table": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["session_id", "provider"],
        "additionalProperties": false,
        "properties": {
          "session_id": { "type": "string" },
          "provider":   { "type": "string" },
          "worker":     { "type": ["string", "null"] },
          "bead":       { "type": ["string", "null"] },
          "strand":     { "type": ["string", "null"] }
        }
      },
      "description": "Mapping of CLI session IDs to their worker/bead aliases (dual-identity invariant §3.4)."
    },
    "backup_timestamps": {
      "type": "object",
      "required": ["last_success_unix", "last_success_iso", "last_size_bytes"],
      "additionalProperties": false,
      "properties": {
        "last_success_unix": { "type": "integer", "description": "Unix timestamp (seconds) of last successful backup, 0 if never." },
        "last_success_iso":  { "type": ["string", "null"], "format": "date-time", "description": "ISO 8601 of last successful backup, null if never." },
        "last_size_bytes":   { "type": "integer", "minimum": 0, "description": "Size of last backup in bytes, 0 if never." }
      },
      "description": "Backup health indicators (§15, §16.6)."
    },
    "fleet_db_path":         { "type": "string" },
    "fleet_db_size_bytes":   { "type": "integer", "minimum": 0 },
    "fleet_db_wal_size_bytes": { "type": "integer", "minimum": 0 },
    "open_stitches":         { "type": "integer", "minimum": 0 },
    "total_beads":           { "type": "integer", "minimum": 0 },
    "projects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Names of all projects currently known to the supervisor."
    }
  },
  "schema_version": "1.0.0"
}
