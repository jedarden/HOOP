{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hoop.dev/schemas/pattern_member.json",
  "title": "PatternMember",
  "description": "Membership of a stitch in a pattern",
  "type": "object",
  "required": ["pattern_id", "stitch_id", "schema_version"],
  "properties": {
    "pattern_id": {
      "type": "string",
      "format": "uuid",
      "description": "Pattern ID"
    },
    "stitch_id": {
      "type": "string",
      "format": "uuid",
      "description": "Stitch ID"
    },
    "added_at": {
      "type": "string",
      "format": "date-time",
      "description": "When stitch was added"
    },
    "added_by": {
      "type": ["string", "null"],
      "description": "Who added this stitch"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    }
  },
  "schema_version": "1.0.0"
}
